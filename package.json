{
  "name": "rishfy",
  "version": "0.1.0",
  "private": true,
  "description": "Rishfy — Tanzania's first D5-licensed ride-sharing platform",
  "workspaces": [
    "services/*",
    "shared/*",
    "admin"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "lint": "eslint 'services/*/src/**/*.ts' 'shared/*/src/**/*.ts'",
    "lint:fix": "eslint 'services/*/src/**/*.ts' 'shared/*/src/**/*.ts' --fix",
    "format": "prettier --write 'services/*/src/**/*.ts' 'shared/*/src/**/*.ts'",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "proto:generate": "bash scripts/generate-protos.sh",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "migrate:all": "bash scripts/dev.sh migrate",
    "seed": "bash scripts/seed.sh",
    "audit:fix": "npm audit fix --workspaces"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
