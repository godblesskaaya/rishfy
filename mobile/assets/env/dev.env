# Development environment config
# Points at the Rishfy Docker stack running on your host machine.
#
# Android emulator uses 10.0.2.2 to reach the host's localhost.
# iOS simulator uses localhost directly — change this file on iOS builds.
API_BASE_URL=http://10.0.2.2
WS_BASE_URL=ws://10.0.2.2/ws
GOOGLE_MAPS_API_KEY=
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
