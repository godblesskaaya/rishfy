# Base URL of this Next.js app
NEXTAUTH_URL=http://localhost:3000

# NextAuth signing secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=replace_me_with_32_byte_hex

# Rishfy API gateway
RISHFY_API_URL=http://localhost

# Admin service token — used for server-side calls that need elevated scope
RISHFY_ADMIN_SERVICE_TOKEN=

# Google Maps (for route visualizations in admin)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Environment flag
NEXT_PUBLIC_APP_ENV=development
